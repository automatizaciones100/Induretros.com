ENVIRONMENT=production
DATABASE_URL=postgresql://user:password@localhost:5432/induretros
# Genera con: openssl rand -hex 32
SECRET_KEY=CHANGE_THIS_generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
FRONTEND_URL=https://www.induretros.com
# Docs API: false en producción (siempre), true solo en desarrollo local
SHOW_DOCS=false
# Cloudflare Turnstile — obtén las claves en https://dash.cloudflare.com
# Claves de test (siempre pasan): secret=1x0000000000000000000000000000000AA
TURNSTILE_SECRET_KEY=
# Google Sign-In Client ID (no es secreto). Vacío deshabilita /api/auth/google.
# Obtén el Client ID en https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# AWS S3 para imágenes UGC. En dev déjalo vacío — usará filesystem local.
# En prod (ENVIRONMENT=production) es obligatorio.
# Credenciales: en App Runner se asignan vía IAM Instance Profile (NO usar
# AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY en producción).
AWS_S3_BUCKET=
AWS_REGION=sa-east-1
# URL pública del CDN (CloudFront) que sirve el bucket. Sin esto, public_url
# devuelve el endpoint S3 directo (sólo funciona si el bucket es público).
# Ejemplo prod: https://cdn.induretros.com
CDN_BASE_URL=
