NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=https://induretros.com
# Cloudflare Turnstile — obtén las claves en https://dash.cloudflare.com
# Clave de test (siempre pasa): 1x00000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Google Sign-In Client ID (no es secreto). Vacío oculta el botón "Continuar con Google".
# Obtén el Client ID en https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
